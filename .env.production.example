# Halal Graph — PRODUCTION environment
# Copy to .env on your server:  cp .env.production.example .env

# === REQUIRED ===
# Public URL (no trailing slash) — used by frontend build & CORS
NEXT_PUBLIC_API_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com

# Strong random secret (generate: openssl rand -hex 32)
JWT_SECRET=

# === Production API ===
PRODUCTION=true
LIVE_SIMULATOR_ENABLED=false
UVICORN_WORKERS=1

# === Prevention ===
MITIGATION_AUTO_ENABLED=true
MITIGATION_MODE=simulated
MITIGATION_FILTER_BLOCKED_FLOWS=true

# === Ports (host) ===
HTTP_PORT=80
HTTPS_PORT=443

# === Optional SIEM integration ===
# MITIGATION_MODE=webhook
# MITIGATION_WEBHOOK_URL=https://your-siem.example.com/events
# REDIS_URL=redis://redis:6379/0

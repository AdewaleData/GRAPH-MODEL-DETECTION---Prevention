# Halal Graph — environment template (copy to .env)

# === Required for production ===
JWT_SECRET=change-me-to-a-long-random-string

# === API prevention / mitigation ===
MITIGATION_AUTO_ENABLED=true
MITIGATION_MODE=simulated
# MITIGATION_MODE=iptables   # Linux host with CAP_NET_ADMIN only
# MITIGATION_MODE=webhook      # POST to SOAR/SIEM
MITIGATION_WEBHOOK_URL=
MITIGATION_BLOCK_TOP_K=5
MITIGATION_RATE_LIMIT_TOP_K=3
MITIGATION_QUARANTINE_TOP_K=2
MITIGATION_FILTER_BLOCKED_FLOWS=true
MITIGATION_TTL_HOURS=24

# === Optional ===
REDIS_URL=redis://redis:6379/0
LIVE_SIMULATOR_ENABLED=true
CORS_ORIGINS=http://localhost,http://localhost:3000

# === Frontend build (docker compose) ===
NEXT_PUBLIC_API_URL=http://localhost
